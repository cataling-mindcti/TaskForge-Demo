				{
					"name": "13. Security Headers Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200 OK', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Cache-Control: no-store header present', function () {",
									"    var cacheControl = pm.response.headers.get('Cache-Control');",
									"    pm.expect(cacheControl).to.include('no-cache');",
									"    pm.expect(cacheControl).to.include('no-store');",
									"});",
									"pm.test('Content-Security-Policy header present', function () {",
									"    var csp = pm.response.headers.get('Content-Security-Policy');",
									"    pm.expect(csp).to.include(\"script-src 'self'\");",
									"});",
									"pm.test('X-Frame-Options header present', function () {",
									"    pm.expect(pm.response.headers.get('X-Frame-Options')).to.eql('DENY');",
									"});"
								]
							}
						}
					],
